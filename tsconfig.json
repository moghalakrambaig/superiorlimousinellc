{
  "files": [],
  "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" }
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },

    "jsx": "react-jsx",

    "strict": true,
    "skipLibCheck": true,
    "allowJs": true,

    "forceConsistentCasingInFileNames": true,

    "moduleResolution": "bundler"
  }
}